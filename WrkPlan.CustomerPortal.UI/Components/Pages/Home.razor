@page "/"

<div class="hero-section">
    <div class="hero-badge">
        <span class="pulse-dot"></span>
        Live Multi-Tenant Environment
    </div>
    <h1 class="hero-title">One Platform.<br />Two Powerful Experiences.</h1>
    <p class="hero-sub">
        Run customer-facing portals and internal hub operations from a single
        enterprise-grade, animated control surface.
    </p>
    <div class="hero-cta">
        <a class="btn-hero primary" href="/auth/customer-login">
            &#128100; Customer Portal &rarr;
        </a>
        <a class="btn-hero secondary" href="/auth/admin-login">
            &#128737; Admin Hub &rarr;
        </a>
    </div>
</div>

<section class="cards-grid">
    <a class="feature-card" href="/auth/customer-login">
        <div class="feature-icon teal">&#127968;</div>
        <h3>Customer Portal</h3>
        <p>Onboarding, invoices, contracts, support tickets, and complete self-service operations for your clients.</p>
        <p style="margin-top:0.8rem;font-weight:700;font-size:0.82rem;color:var(--c-teal-500);">Sign In &rarr;</p>
    </a>
    <a class="feature-card" href="/auth/admin-login">
        <div class="feature-icon sky">&#128737;</div>
        <h3>Customer Hub</h3>
        <p>Tenant provisioning, lifecycle management, cross-tenant analytics, and billing operations.</p>
        <p style="margin-top:0.8rem;font-weight:700;font-size:0.82rem;color:var(--c-sky-500);">Admin Sign In &rarr;</p>
    </a>
    <div class="feature-card" style="opacity:0.65;">
        <div class="feature-icon indigo">&#128279;</div>
        <h3>Partner Portal</h3>
        <p>Reserved integration space for partner-only workflows and delegated access patterns. Coming soon.</p>
        <p style="margin-top:0.8rem;"><span class="badge badge-warn">Coming Soon</span></p>
    </div>
    <div class="feature-card" style="opacity:0.65;">
        <div class="feature-icon orange">&#128202;</div>
        <h3>Analytics Suite</h3>
        <p>Cross-tenant reporting dashboards, revenue trends, and operational KPIs in real time.</p>
        <p style="margin-top:0.8rem;"><span class="badge badge-warn">Coming Soon</span></p>
    </div>
</section>

<div class="panel" style="text-align:center;padding:1.6rem;">
    <p style="margin:0;color:var(--text-muted);font-size:0.85rem;font-weight:600;letter-spacing:0.05rem;text-transform:uppercase;">
        Built on .NET 8 &bull; Clean Architecture &bull; Multi-Tenant &bull; JWT Secured &bull; EF Core
    </p>
</div>
