@page "/customerhub/assign-subscriptions"
@page "/customerhub/quotes-contracts"
@page "/customerhub/support-management"
@page "/customerhub/integrations"
@implements IDisposable
@using Microsoft.AspNetCore.Components.Forms
@inject PortalApiClient Api
@inject SessionService Session
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .contract-body-display {
        position: relative;
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.09), rgba(6, 182, 212, 0.08));
        border: 1px solid rgba(6, 182, 212, 0.3);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
        overflow: hidden;
    }

    .contract-body-display::before {
        content: "";
        position: absolute;
        inset: -65%;
        background: conic-gradient(from 0deg, rgba(34, 197, 94, 0.18), rgba(6, 182, 212, 0.16), rgba(34, 197, 94, 0.18));
        animation: contract-body-sweep 9s linear infinite;
        pointer-events: none;
    }

    .contract-body-text {
        position: relative;
        margin: 0;
        white-space: pre-wrap;
        line-height: 1.62;
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-family: 'Sora', sans-serif;
    }

    @@keyframes contract-body-sweep {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<div class="page-header">
    <h2>@Title</h2>
    <p>@Subtitle</p>
</div>

@if (RouteKey == "quotes-contracts")
{
    <div class="cards-grid">
        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.9rem;">Generate Contract</h3>
            <div class="field-row" style="grid-template-columns:1fr 1fr;">
                <div>
                    <label style="display:block;margin-bottom:0.25rem;color:var(--text-muted);font-size:0.78rem;">Customer Profile</label>
                    <select @bind="_selectedProfileId">
                        <option value="">Select profile</option>
                        @foreach (var profile in _profiles)
                        {
                            <option value="@profile.CustomerProfileId">@profile.TenantName / @profile.ContactEmail</option>
                        }
                    </select>
                </div>
                <div>
                    <label style="display:block;margin-bottom:0.25rem;color:var(--text-muted);font-size:0.78rem;">Contract Number</label>
                    <input @bind="_contractNumber" placeholder="CNT-2026-001" />
                </div>
            </div>

            <div class="field-row" style="grid-template-columns:1fr 1fr;margin-top:0.65rem;">
                <input @bind="_contractTitle" placeholder="Contract title" />
                <input @bind="_contractVersion" placeholder="v1" />
            </div>
            <textarea @bind="_contractHeader" rows="2" style="margin-top:0.65rem;" placeholder="Header text"></textarea>
            <textarea @bind="_contractBody" rows="4" style="margin-top:0.55rem;" placeholder="Body/JSON content"></textarea>

            <div class="panel" style="padding:0.8rem;margin-top:0.65rem;">
                <div style="font-weight:700;margin-bottom:0.45rem;">E-Sign Fields</div>
                @if (_eSignFields.Count == 0)
                {
                    <p style="margin:0;color:var(--text-muted);font-size:0.84rem;">No fields added yet.</p>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:0.45rem;">
                        @foreach (var field in _eSignFields)
                        {
                            <div class="field-row" style="grid-template-columns:1.5fr 0.8fr 0.8fr auto;align-items:center;">
                                <input @bind="field.Label" placeholder="e.g. Authorised Signatory" />
                                <select @bind="field.Type">
                                    <option value="signature">signature</option>
                                    <option value="text">text</option>
                                    <option value="date">date</option>
                                </select>
                                <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.84rem;"><input type="checkbox" @bind="field.Required" /> Required</label>
                                <button type="button" class="ghost-btn" style="padding:0.3rem 0.55rem;" @onclick="(() => RemoveESignField(field.Id))">&#10005;</button>
                            </div>
                        }
                    </div>
                }

                <button type="button" class="ghost-btn" style="margin-top:0.6rem;" @onclick="AddESignField">Add Field</button>
            </div>

            <div class="field-row" style="grid-template-columns:1fr 1fr;margin-top:0.65rem;">
                <input @bind="_effectiveDateText" placeholder="yyyy-MM-dd" />
                <input @bind="_expiryDateText" placeholder="yyyy-MM-dd" />
            </div>

            <div style="display:flex;gap:0.55rem;flex-wrap:wrap;margin-top:0.75rem;">
                <button @onclick="CreateGeneratedContractAsync" disabled="@_contractBusy">@(_contractBusy ? "Saving..." : "Create Generated Contract")</button>
                <button class="ghost-btn" @onclick="LoadContractDataAsync">Refresh</button>
            </div>

            <div class="panel" style="padding:0.8rem;margin-top:0.75rem;">
                <div style="font-weight:700;margin-bottom:0.35rem;">Manual Contract Upload</div>
                <InputFile OnChange="OnManualContractSelected" accept="application/pdf" />
                <button style="margin-top:0.55rem;" @onclick="UploadManualContractAsync" disabled="@_contractBusy">Upload Manual Contract</button>
            </div>
        </article>

        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.9rem;">Contracts List</h3>
            @if (_contracts.Count == 0)
            {
                <p style="color:var(--text-muted);margin:0;">No contracts found.</p>
            }
            else
            {
                <ul class="data-list">
                    @foreach (var contract in _contracts)
                    {
                        <li style="cursor:pointer;" @onclick="() => SelectContractAsync(contract.Id)">
                            <span class="list-label">@contract.ContractNumber - @contract.Title</span>
                            <span style="display:flex;gap:0.45rem;align-items:center;">
                                <span class="tag">@contract.Status</span>
                                @if (string.Equals(contract.ESignStatus, "AwaitingSignature", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge badge-warn">Awaiting Signature</span>
                                }
                                else if (string.Equals(contract.ESignStatus, "Signed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge badge-ok">Signed Back Copy</span>
                                }
                                else
                                {
                                    <span class="tag">No E-Sign</span>
                                }
                                @if (string.Equals(contract.ESignStatus, "Draft", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(contract.ESignFieldsJson))
                                {
                                    <button type="button" class="ghost-btn" style="padding:0.3rem 0.6rem;font-size:0.78rem;" @onclick:stopPropagation="true" @onclick="(() => SendForSigningAsync(contract.Id))">Send for Signing</button>
                                }
                                @if (_selectedContract?.Id == contract.Id)
                                {
                                    <span class="badge badge-ok">Selected</span>
                                }
                                <button type="button" class="ghost-btn" style="padding:0.3rem 0.6rem;font-size:0.78rem;" @onclick:stopPropagation="true" @onclick="(() => OpenContractModalAsync(contract.Id))">View</button>
                            </span>
                        </li>
                    }
                </ul>
            }

            @if (_selectedContract is not null)
            {
                <div style="margin-top:0.8rem;">
                    <h4 style="margin:0 0 0.45rem;">Transition Status</h4>
                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                        <select @bind="_targetContractStatus" style="max-width:220px;">
                            @foreach (var status in _contractStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                        <input @bind="_transitionNote" placeholder="Optional note" style="max-width:260px;" />
                        <button class="ghost-btn" @onclick="TransitionContractAsync" disabled="@_contractBusy">Apply</button>
                    </div>
                </div>

                <div class="panel" style="padding:0.85rem;margin-top:0.8rem;">
                    <div style="font-weight:700;">E-Sign Status: @_selectedContract.ESignStatus</div>
                    @if (!string.IsNullOrWhiteSpace(_selectedContract.SignedPdfPath))
                    {
                        <button type="button" class="ghost-btn" style="margin-top:0.55rem;" @onclick="DownloadSignedPdfAsync">Download Signed PDF</button>
                    }
                    <button type="button" class="ghost-btn" style="margin-top:0.55rem;" @onclick="(() => OpenContractModalAsync(_selectedContract.Id))">Open Contract Window</button>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_contractMessage))
            {
                <div class="auth-status success" style="margin-top:0.7rem;">@_contractMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(_contractError))
            {
                <div class="auth-status error" style="margin-top:0.7rem;">@_contractError</div>
            }
        </article>
    </div>
}

@if (_showContractModal && _selectedContract is not null)
{
    <div style="position:fixed;inset:0;background:rgba(15,23,42,0.55);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1.2rem;">
        <div class="panel" style="width:min(1120px,96vw);max-height:92vh;overflow:auto;padding:1rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:0.8rem;">
                <div>
                    <div style="font-weight:800;font-size:1.05rem;">@_selectedContract.ContractNumber - @_selectedContract.Title</div>
                    <div style="font-size:0.82rem;color:var(--text-muted);">Status: @_selectedContract.Status | E-Sign: @_selectedContract.ESignStatus</div>
                </div>
                <button class="ghost-btn" @onclick="CloseContractModalAsync">Close</button>
            </div>

            <div style="display:flex;flex-direction:column;gap:0.9rem;margin-top:0.9rem;">
                <!-- toolbar -->
                <div style="display:flex;gap:0.55rem;align-items:center;flex-wrap:wrap;">
                    @if (_selectedContract.Versions.Count > 0)
                    {
                        <button class="ghost-btn" @onclick="(() => DownloadDocumentAsync(_selectedContract.Versions.OrderByDescending(x => x.IsLatest).ThenByDescending(x => x.CreatedUtc).First().Id))">Download Latest</button>
                    }
                    @if (!string.IsNullOrWhiteSpace(_selectedContract.SignedPdfPath))
                    {
                        <button class="ghost-btn" @onclick="DownloadSignedPdfAsync">Download Signed PDF</button>
                    }
                    @if (_adminPreviewLoading)
                    {
                        <span style="font-size:0.82rem;color:var(--text-muted);">Loading preview…</span>
                    }
                </div>

                <!-- two-panel preview -->
                <div style="display:grid;grid-template-columns:1fr 1.2fr;gap:0.9rem;">
                    <div class="panel" style="padding:0.85rem;overflow:auto;max-height:74vh;">
                        <div style="font-weight:700;margin-bottom:0.5rem;font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.04rem;">Contract Body</div>
                        <div class="contract-body-display">
                            <pre class="contract-body-text">@GetDisplayBodyText(_selectedContract)</pre>
                        </div>
                    </div>
                    <div class="panel" style="padding:0.85rem;display:flex;flex-direction:column;gap:0.5rem;">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                            <div style="font-weight:700;font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.04rem;">Document Preview</div>
                            @if (!string.IsNullOrWhiteSpace(_contractPreviewDataUrl))
                            {
                                <a class="ghost-btn" style="padding:0.25rem 0.55rem;font-size:0.78rem;text-decoration:none;" href="@_contractPreviewDataUrl" target="_blank" rel="noopener">Open in new tab</a>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_contractPreviewDataUrl))
                        {
                            <object data="@_contractPreviewDataUrl" type="application/pdf" style="width:100%;flex:1;min-height:60vh;border:1px solid rgba(125,140,160,0.2);border-radius:10px;background:#fff;">
                                <embed src="@_contractPreviewDataUrl" type="application/pdf" style="width:100%;height:100%;" />
                                <div style="padding:1rem;color:var(--text-secondary);font-size:0.85rem;">
                                    Inline PDF preview is not supported by this browser. <a href="@_contractPreviewDataUrl" target="_blank" rel="noopener">Open in new tab</a> or use the Download button above.
                                </div>
                            </object>
                        }
                        else if (_adminPreviewError)
                        {
                            <div style="padding:1.2rem;background:rgba(239,68,68,0.06);border-radius:10px;color:var(--text-secondary);font-size:0.88rem;">
                                <div style="font-weight:700;margin-bottom:0.35rem;">Preview unavailable</div>
                                <div>The document could not be loaded for inline view. Use the Download button above to open it.</div>
                            </div>
                        }
                        else if (_adminPreviewLoading)
                        {
                            <div style="display:flex;align-items:center;justify-content:center;min-height:200px;">
                                <div class="ticket-spinner"></div>
                            </div>
                        }
                        else
                        {
                            <div style="padding:1.2rem;background:rgba(99,102,241,0.05);border-radius:10px;color:var(--text-secondary);font-size:0.88rem;">
                                No document version attached to this contract yet.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else if (RouteKey == "support-management")
{
    <div class="cards-grid">
        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.9rem;">Support Inbox</h3>
            <div class="panel" style="padding:0.75rem;margin-bottom:0.75rem;display:flex;gap:0.55rem;align-items:center;flex-wrap:wrap;">
                <input @bind="_supportSearch" placeholder="Search by ticket no/subject" style="max-width:240px;" />
                <select @bind="_supportStatusFilter" style="max-width:180px;">
                    <option value="">All statuses</option>
                    @foreach (var status in _supportStatuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <select @bind="_supportPriorityFilter" style="max-width:180px;">
                    <option value="">All priorities</option>
                    <option value="Low">Low</option>
                    <option value="Normal">Normal</option>
                    <option value="High">High</option>
                    <option value="Critical">Critical</option>
                </select>
                <button class="ghost-btn" @onclick="LoadSupportInboxAsync">Apply Filters</button>
            </div>

            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.65rem;">
                <span class="tag">Open: @_supportOpen</span>
                <span class="tag">In Progress: @_supportInProgress</span>
                <span class="tag">Resolved: @_supportResolved</span>
                <span class="tag">Overdue: @_supportOverdue</span>
            </div>

            @if (_supportTickets.Count == 0)
            {
                <p style="color:var(--text-muted);margin:0;">No support tickets found for selected filters.</p>
            }
            else
            {
                <ul class="data-list">
                    @foreach (var ticket in _supportTickets)
                    {
                        <li style="cursor:pointer;" @onclick="() => SelectSupportTicketAsync(ticket.Id)">
                            <span class="list-label">@ticket.TicketNumber - @ticket.Subject</span>
                            <span style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">
                                <span class="badge @(ticket.Priority is "High" or "Critical" ? "badge-error" : "badge-warn")">@ticket.Priority</span>
                                <span class="tag">@ticket.Status</span>
                                @if (!string.IsNullOrWhiteSpace(ticket.TenantName))
                                {
                                    <span class="tag">@ticket.TenantName</span>
                                }
                            </span>
                        </li>
                    }
                </ul>
            }
        </article>

        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.9rem;">Ticket Actions</h3>
            @if (_selectedSupportTicket is null)
            {
                <p style="color:var(--text-muted);margin:0;">Select a ticket to reply, change status, or resolve.</p>
            }
            else
            {
                <div class="field-row" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));margin-bottom:0.75rem;">
                    <div class="panel" style="padding:0.6rem 0.8rem;">
                        <div style="font-size:0.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05rem;">Ticket</div>
                        <div style="font-weight:700;">@_selectedSupportTicket.TicketNumber</div>
                    </div>
                    <div class="panel" style="padding:0.6rem 0.8rem;">
                        <div style="font-size:0.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05rem;">Status</div>
                        <div style="font-weight:700;">@_selectedSupportTicket.Status</div>
                    </div>
                    <div class="panel" style="padding:0.6rem 0.8rem;">
                        <div style="font-size:0.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05rem;">Resolved In</div>
                        <div style="font-weight:700;">@(_selectedSupportTicket.ResolvedInDays.HasValue ? $"{_selectedSupportTicket.ResolvedInDays} day(s)" : "Pending")</div>
                    </div>
                </div>

                <textarea @bind="_adminReply" rows="3" placeholder="Reply to customer"></textarea>
                <button class="ghost-btn" style="margin-top:0.5rem;" @onclick="ReplySupportTicketAsync" disabled="@_supportBusy">Send Reply</button>

                <div class="field-row" style="grid-template-columns:1fr 1fr;margin-top:0.8rem;">
                    <select @bind="_targetSupportStatus">
                        @foreach (var status in _supportStatuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                    <input @bind="_supportStatusNote" placeholder="Status note" />
                </div>
                <button class="ghost-btn" style="margin-top:0.5rem;" @onclick="ChangeSupportStatusAsync" disabled="@_supportBusy">Change Status</button>

                <textarea @bind="_resolutionMessage" rows="3" style="margin-top:0.8rem;" placeholder="Resolution message"></textarea>
                <button style="margin-top:0.5rem;" @onclick="ResolveSupportTicketAsync" disabled="@_supportBusy">Mark Resolved</button>

                <h4 style="margin:0.85rem 0 0.35rem;">Conversation</h4>
                <ul class="data-list">
                    @foreach (var message in _selectedSupportTicket.Messages)
                    {
                        <li>
                            <span class="list-label">@message.Message</span>
                            <span style="display:flex;gap:0.35rem;align-items:center;">
                                <span class="tag">@message.AuthorRole</span>
                                <span class="tag">@message.CreatedUtc.ToString("dd MMM HH:mm")</span>
                            </span>
                        </li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(_supportMessage))
            {
                <div class="auth-status success" style="margin-top:0.7rem;">@_supportMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(_supportError))
            {
                <div class="auth-status error" style="margin-top:0.7rem;">@_supportError</div>
            }
        </article>
    </div>
}
else
{
    <article class="panel" style="padding:1.1rem;">
        @if (RouteKey == "assign-subscriptions")
        {
            <p style="margin:0 0 0.75rem;color:var(--text-secondary);">Use tenant-level controls to assign or upgrade plans.</p>
            <a href="/customerhub/subscription-plans" class="btn-hero secondary" style="padding:0.55rem 1rem;font-size:0.84rem;">Open Subscription Plans</a>
        }
        else
        {
            <p style="margin:0;color:var(--text-secondary);">This admin workspace is ready for operational workflows and guarded for WrkPlan administrators only.</p>
        }
    </article>
}

@code {
    private string RouteKey = "";
    private string Title = "Admin Area";
    private string Subtitle = "";

    private List<ContractCustomerProfileOptionDto> _profiles = [];
    private List<ContractSummaryDto> _contracts = [];
    private ContractDetailDto? _selectedContract;
    private string _selectedProfileId = string.Empty;
    private string _contractNumber = string.Empty;
    private string _contractTitle = "WrkPlan Service Agreement";
    private string _contractVersion = "v1";
    private string _contractHeader = "Service terms";
    private string _contractBody = "{}";
    private string _effectiveDateText = DateTime.UtcNow.ToString("yyyy-MM-dd");
    private string _expiryDateText = DateTime.UtcNow.AddYears(1).ToString("yyyy-MM-dd");
    private string _targetContractStatus = "Draft";
    private string _transitionNote = string.Empty;
    private List<ESignFieldUi> _eSignFields = [];
    private bool _contractBusy;
    private string? _contractMessage;
    private string? _contractError;
    private string? _manualContractFileBase64;
    private string _manualContractFileName = "manual-contract.pdf";
    private string _manualContractContentType = "application/pdf";
    private bool _showContractModal;
    private string? _contractPreviewDataUrl;
    private bool _adminPreviewLoading;
    private bool _adminPreviewError;
    private CancellationTokenSource? _contractPollingCts;
    private readonly List<string> _contractStatuses = ["Draft", "Sent to Customer", "Viewed", "Signature Pending", "Signed by Customer", "Signed by Both", "Completed", "Rejected/Needs Revision"];

    private List<SupportTicketDto> _supportTickets = [];
    private SupportTicketDetailDto? _selectedSupportTicket;
    private string _supportSearch = string.Empty;
    private string _supportStatusFilter = string.Empty;
    private string _supportPriorityFilter = string.Empty;
    private string _targetSupportStatus = "In Progress";
    private string _supportStatusNote = string.Empty;
    private string _adminReply = string.Empty;
    private string _resolutionMessage = string.Empty;
    private bool _supportBusy;
    private string? _supportMessage;
    private string? _supportError;
    private int _supportOpen;
    private int _supportInProgress;
    private int _supportResolved;
    private int _supportOverdue;
    private readonly List<string> _supportStatuses = ["Open", "In Progress", "Awaiting Customer", "Resolved", "Closed"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Session.TryRestoreAsync();
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/auth/admin-login", forceLoad: true);
            return;
        }
        if (Session.Auth?.Role != "WrkPlanAdmin")
        {
            Nav.NavigateTo("/customerportal/dashboard", forceLoad: true);
            return;
        }

        var path = Nav.ToBaseRelativePath(Nav.Uri).ToLowerInvariant();
        RouteKey = path.Split('/', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? "";

        (Title, Subtitle) = RouteKey switch
        {
            "assign-subscriptions" => ("Assign/Upgrade Subscriptions", "Manage tenant plan assignments and upgrades."),
            "billing-monitoring" => ("Billing & Payments Monitoring", "Track payment health, anomalies, and aging trends."),
            "quotes-contracts" => ("Quotes & Contracts", "Handle commercial quotes and contract lifecycle."),
            "announcements-management" => ("Announcements Management", "Publish and manage tenant communications."),
            "support-management" => ("Support Management", "Review escalations and service quality."),
            "reports" => ("Reports / Audit Logs", "Analyze system usage and audit activity."),
            "integrations" => ("Integrations", "Configure integration endpoints and sync behavior."),
            "settings" => ("Settings", "Platform-level configuration and governance controls."),
            _ => ("Admin Area", "Role-focused operations.")
        };

        if (RouteKey == "quotes-contracts")
        {
            await LoadContractDataAsync();
            StartContractPolling();
        }
        else if (RouteKey == "support-management")
        {
            await LoadSupportInboxAsync();
        }

        StateHasChanged();
    }

    private async Task LoadContractDataAsync()
    {
        _contractError = null;
        var profileResponse = await Api.GetContractCustomerProfilesAsync();
        _profiles = profileResponse?.Data?.ToList() ?? [];

        var contractsResponse = await Api.GetContractsAsync();
        _contracts = contractsResponse?.Data?
            .OrderByDescending(x => string.Equals(x.ESignStatus, "Signed", StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(x => string.Equals(x.ESignStatus, "AwaitingSignature", StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(x => x.EffectiveUtc)
            .ToList() ?? [];

        if (_contracts.Count > 0)
        {
            await SelectContractAsync(_contracts[0].Id);
        }
    }

    private async Task SelectContractAsync(Guid id)
    {
        var detail = await Api.GetContractDetailAsync(id);
        _selectedContract = detail?.Success == true ? detail.Data : null;

        if (_selectedContract is not null)
        {
            _eSignFields = _selectedContract.ESignFields
                .OrderBy(x => x.Order)
                .Select(x => new ESignFieldUi
                {
                    Id = x.Id,
                    Label = x.Label,
                    Type = x.Type,
                    Required = x.Required
                })
                .ToList();
        }
        else
        {
            _eSignFields = [];
        }

        StateHasChanged();
    }

    private async Task OpenContractModalAsync(Guid contractId)
    {
        if (_selectedContract is null || _selectedContract.Id != contractId)
        {
            await SelectContractAsync(contractId);
        }

        if (_selectedContract is null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(_contractPreviewDataUrl))
        {
            await JS.InvokeVoidAsync("wrkplan.revokeObjectUrl", _contractPreviewDataUrl);
        }

        _contractPreviewDataUrl = null;
        _adminPreviewLoading = true;
        _adminPreviewError = false;
        _showContractModal = true;
        StateHasChanged();

        (byte[] Bytes, string ContentType, string FileName)? file = null;
        try
        {
            if (string.Equals(_selectedContract.ESignStatus, "Signed", StringComparison.OrdinalIgnoreCase)
                && !string.IsNullOrWhiteSpace(_selectedContract.SignedPdfPath))
            {
                file = await Api.DownloadSignedPdfAsync(_selectedContract.Id);
            }

            if (file is null)
            {
                var latest = _selectedContract.Versions.OrderByDescending(x => x.IsLatest).ThenByDescending(x => x.CreatedUtc).FirstOrDefault();
                if (latest is not null)
                {
                    file = await Api.DownloadContractDocumentAsync(latest.Id);
                }
            }

            if (file is not null)
            {
                var base64 = Convert.ToBase64String(file.Value.Bytes);
                _contractPreviewDataUrl = await JS.InvokeAsync<string>("wrkplan.createObjectUrlFromBytes", file.Value.ContentType, base64);
            }
        }
        catch
        {
            _adminPreviewError = true;
        }
        finally
        {
            _adminPreviewLoading = false;
            StateHasChanged();
        }
    }

    private async Task CloseContractModalAsync()
    {
        if (!string.IsNullOrWhiteSpace(_contractPreviewDataUrl))
        {
            await JS.InvokeVoidAsync("wrkplan.revokeObjectUrl", _contractPreviewDataUrl);
        }

        _showContractModal = false;
        _contractPreviewDataUrl = null;
        _adminPreviewLoading = false;
        _adminPreviewError = false;
    }

