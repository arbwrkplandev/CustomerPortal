    private void StartContractPolling()
    {
        if (_contractPollingCts is not null)
        {
            return;
        }

        _contractPollingCts = new CancellationTokenSource();
        var token = _contractPollingCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(20));
                while (await timer.WaitForNextTickAsync(token))
                {
                    await InvokeAsync(async () =>
                    {
                        if (RouteKey == "quotes-contracts")
                        {
                            await LoadContractDataAsync();
                        }
                    });
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

