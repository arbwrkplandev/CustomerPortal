    private static string GetDisplayBodyText(ContractDetailDto contract)
    {
        var body = NormalizeContractBodyText(contract.BodyJson);
        if (LooksLikeBinaryBody(body))
        {
            return $"WrkPlan\n{contract.Title}\n\nContract Number: {contract.ContractNumber}\nVersion: {contract.Version}\n\nReadable content is being prepared. Use the preview panel on the right for the fully formatted PDF.";
        }

        return body;
    }

    private static bool LooksLikeBinaryBody(string value)
    {
        var normalized = NormalizeContractBodyText(value);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return false;
        }

        if (normalized.StartsWith("%PDF-", StringComparison.Ordinal))
        {
            return true;
        }

        var syntaxSample = normalized.Length > 900 ? normalized[..900] : normalized;
        if (syntaxSample.Contains("/Filter/FlateDecode", StringComparison.OrdinalIgnoreCase)
            || syntaxSample.Contains("endstream", StringComparison.OrdinalIgnoreCase)
            || (syntaxSample.Contains(" obj", StringComparison.Ordinal) && syntaxSample.Contains("stream", StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }

        var sampleLength = Math.Min(normalized.Length, 450);
        var nonPrintable = 0;
        var replacementCount = 0;
        for (var i = 0; i < sampleLength; i++)
        {
            var ch = normalized[i];
            if (char.IsControl(ch) && ch != '\r' && ch != '\n' && ch != '\t')
            {
                nonPrintable++;
            }

            if (ch == '\uFFFD' || ch == '�')
            {
                replacementCount++;
            }
        }

        return nonPrintable > 14 || replacementCount > 10;
    }

    private static string NormalizeContractBodyText(string? value)
    {
        return (value ?? string.Empty).TrimStart('\uFEFF', '\0', ' ', '\t', '\r', '\n');
    }

