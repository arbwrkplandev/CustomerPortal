@page "/customerhub/announcements-management"
@inject PortalApiClient Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="page-header">
    <h2>Announcements Management</h2>
    <p>Create, edit, publish, and target announcements to all or selected tenants.</p>
</div>

@if (!_ready)
{
    <div class="ticket-loading"><div class="ticket-spinner"></div></div>
}
else
{
    <div class="cards-grid">
        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.8rem;">Announcement Editor</h3>
            <input @bind="_title" placeholder="Title" />
            <input @bind="_topic" placeholder="Topic" style="margin-top:0.5rem;" />
            <textarea @bind="_message" rows="4" style="margin-top:0.5rem;" placeholder="Message"></textarea>

            <div class="field-row" style="grid-template-columns:1fr 1fr;margin-top:0.5rem;">
                <label><input type="checkbox" @bind="_isPublished" /> Publish now</label>
                <label><input type="checkbox" @bind="_isGlobal" /> Target all tenants</label>
            </div>

            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.6rem;">
                <button @onclick="SaveAsync" disabled="@_busy">@(_busy ? "Saving..." : (_editingId.HasValue ? "Update Announcement" : "Create Announcement"))</button>
                @if (_editingId.HasValue)
                {
                    <button class="ghost-btn" @onclick="ClearEditor">Cancel Edit</button>
                }
            </div>
        </article>

        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.8rem;">Announcements</h3>
            <div class="panel" style="padding:0.7rem;margin-bottom:0.7rem;display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                <input @bind="_search" placeholder="Search title/topic/message" style="max-width:260px;" />
                <select @bind="_publishedFilter" style="max-width:180px;">
                    <option value="">All</option>
                    <option value="published">Published</option>
                    <option value="unpublished">Unpublished</option>
                </select>
                <button class="ghost-btn" @onclick="LoadAsync">Apply</button>
            </div>

            @if (_items.Count == 0)
            {
                <p style="color:var(--text-muted);">No announcements found.</p>
            }
            else
            {
                <ul class="data-list">
                    @foreach (var item in _items)
                    {
                        <li>
                            <span class="list-label">@item.Title (@item.Topic)</span>
                            <span style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">
                                <span class="badge @(item.IsPublished ? "badge-ok" : "badge-warn")">@(item.IsPublished ? "Published" : "Draft")</span>
                                <button class="ghost-btn" style="padding:0.25rem 0.55rem;font-size:0.78rem;" @onclick="() => Edit(item)">Edit</button>
                                <button class="ghost-btn" style="padding:0.25rem 0.55rem;font-size:0.78rem;" @onclick="() => TogglePublishAsync(item)">@(item.IsPublished ? "Unpublish" : "Publish")</button>
                                <button class="ghost-btn" style="padding:0.25rem 0.55rem;font-size:0.78rem;" @onclick="() => DeleteAsync(item.Id)">Delete</button>
                            </span>
                        </li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="auth-status error" style="margin-top:0.7rem;">@_error</div>
            }
            @if (!string.IsNullOrWhiteSpace(_success))
            {
                <div class="auth-status success" style="margin-top:0.7rem;">@_success</div>
            }
        </article>
    </div>
}

@code {
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _success;

    private Guid? _editingId;
    private string _title = string.Empty;
    private string _topic = string.Empty;
    private string _message = string.Empty;
    private bool _isPublished = true;
    private bool _isGlobal = true;

    private string _search = string.Empty;
    private string _publishedFilter = string.Empty;
    private List<AnnouncementDto> _items = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Session.TryRestoreAsync();
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/auth/admin-login", true);
            return;
        }
        if (Session.Auth?.Role != "WrkPlanAdmin")
        {
            Nav.NavigateTo("/customerportal/dashboard", true);
            return;
        }

        await LoadAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _error = null;
        bool? isPublished = _publishedFilter switch
        {
            "published" => true,
            "unpublished" => false,
            _ => null
        };

        var response = await Api.GetAdminAnnouncementsAsync(new AnnouncementFilterDto(
            PageNumber: 1,
            PageSize: 50,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
            FromUtc: null,
            ToUtc: null,
            Topic: null,
            IsPublished: isPublished));

        if (response?.Success != true || response.Data is null)
        {
            _error = response?.Error?.Message ?? "Unable to load announcements.";
            _items = [];
        }
        else
        {
            _items = response.Data.Items.ToList();
        }

        StateHasChanged();
    }

    private void Edit(AnnouncementDto item)
    {
        _editingId = item.Id;
        _title = item.Title;
        _topic = item.Topic ?? string.Empty;
        _message = item.Message;
        _isPublished = item.IsPublished;
        _isGlobal = item.IsGlobal;
        _success = null;
        _error = null;
    }

    private void ClearEditor()
    {
        _editingId = null;
        _title = string.Empty;
        _topic = string.Empty;
        _message = string.Empty;
        _isPublished = true;
        _isGlobal = true;
    }

    private async Task SaveAsync()
    {
        _error = _success = null;
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_message))
        {
            _error = "Title and message are required.";
            return;
        }

        _busy = true;
        try
        {
            var response = await Api.UpsertAnnouncementAsync(new UpsertAnnouncementDto(
                _editingId,
                _title,
                _message,
                _topic,
                _isGlobal,
                _isPublished,
                null));

            if (response?.Success == true)
            {
                _success = _editingId.HasValue ? "Announcement updated." : "Announcement created.";
                ClearEditor();
                await LoadAsync();
            }
            else
            {
                _error = response?.Error?.Message ?? "Save failed.";
            }
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task TogglePublishAsync(AnnouncementDto item)
    {
        _error = _success = null;
        var response = await Api.PublishAnnouncementAsync(item.Id, !item.IsPublished);
        if (response?.Success == true)
        {
            _success = item.IsPublished ? "Announcement unpublished." : "Announcement published.";
            await LoadAsync();
        }
        else
        {
            _error = response?.Error?.Message ?? "Publish update failed.";
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        _error = _success = null;
        var response = await Api.DeleteAnnouncementAsync(id);
        if (response?.Success == true)
        {
            _success = "Announcement deleted.";
            await LoadAsync();
        }
        else
        {
            _error = response?.Error?.Message ?? "Delete failed.";
        }
    }
}
