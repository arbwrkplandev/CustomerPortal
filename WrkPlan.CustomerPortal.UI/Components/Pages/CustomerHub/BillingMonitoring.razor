@page "/customerhub/billing-monitoring"
@inject PortalApiClient Api
@inject SessionService Session
@inject NavigationManager Nav

<div class="page-header">
    <h2>Billing Monitoring</h2>
    <p>Tenant billing health, due amounts, renewals, and payment operations.</p>
</div>

@if (!_ready)
{
    <div class="ticket-loading"><div class="ticket-spinner"></div></div>
}
else
{
    <div class="cards-grid">
        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.8rem;">Billing Snapshot</h3>
            <div class="panel" style="padding:0.7rem;display:flex;gap:0.55rem;flex-wrap:wrap;align-items:center;margin-bottom:0.7rem;">
                <input @bind="_search" placeholder="Search tenant/company/plan" style="max-width:240px;" />
                <select @bind="_statusFilter" style="max-width:180px;">
                    <option value="">All statuses</option>
                    <option value="Unpaid">Unpaid</option>
                    <option value="Pending">Pending</option>
                    <option value="Partial">Partial</option>
                    <option value="Paid">Paid</option>
                </select>
                <button class="ghost-btn" @onclick="LoadAsync">Apply</button>
            </div>

            <div style="display:flex;gap:0.45rem;flex-wrap:wrap;margin-bottom:0.7rem;">
                <span class="tag">Overdue: @_overdue</span>
                <span class="tag">Upcoming Renewal: @_upcoming</span>
                <span class="tag">Total: @_totalCount</span>
            </div>

            @if (_items.Count == 0)
            {
                <p style="color:var(--text-muted);">No billing rows found.</p>
            }
            else
            {
                <ul class="data-list">
                    @foreach (var row in _items)
                    {
                        <li style="cursor:pointer;" @onclick="() => SelectRowAsync(row)">
                            <span class="list-label">@row.TenantName - @row.CurrentPlan (@row.BillingCycle)</span>
                            <span style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">
                                <span class="tag">Outstanding @row.Outstanding.ToString("C")</span>
                                <span class="tag">Renewal @row.NextRenewalDate.ToString("dd MMM yyyy")</span>
                                <span class="badge @(row.PaymentStatus == "Paid" ? "badge-ok" : "badge-warn")">@row.PaymentStatus</span>
                            </span>
                        </li>
                    }
                </ul>
            }
        </article>

        <article class="dashboard-card" style="grid-column:span 2;">
            <h3 style="font:700 1rem 'Sora',sans-serif;margin-bottom:0.8rem;">Payment Operations</h3>
            @if (_selected is null)
            {
                <p style="color:var(--text-muted);">Select a tenant row to view history and record manual payment.</p>
            }
            else
            {
                <div class="panel" style="padding:0.7rem;margin-bottom:0.8rem;">
                    <div style="font-weight:700;">@_selected.TenantName</div>
                    <div style="font-size:0.85rem;color:var(--text-muted);">@_selected.CompanyName • @_selected.CurrentPlan • Outstanding @_selected.Outstanding.ToString("C")</div>
                </div>

                <div class="field-row" style="grid-template-columns:1fr 1fr;">
                    <input type="number" step="0.01" @bind="_manualAmount" placeholder="Amount" />
                    <input type="date" @bind="_manualPaidDate" />
                </div>
                <div class="field-row" style="grid-template-columns:1fr 1fr;margin-top:0.5rem;">
                    <select @bind="_manualMode">
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Cash">Cash</option>
                        <option value="UPI">UPI</option>
                        <option value="Card">Card</option>
                        <option value="Cheque">Cheque</option>
                    </select>
                    <input @bind="_manualRef" placeholder="Reference / Txn Id" />
                </div>
                <textarea @bind="_manualNotes" rows="3" style="margin-top:0.5rem;" placeholder="Notes"></textarea>
                <button style="margin-top:0.6rem;" @onclick="RecordManualAsync" disabled="@_busy">@(_busy ? "Saving..." : "Record Manual Payment")</button>

                <h4 style="margin:0.9rem 0 0.35rem;">Payment History</h4>
                @if (_history.Count == 0)
                {
                    <p style="color:var(--text-muted);">No payment history found.</p>
                }
                else
                {
                    <ul class="data-list">
                        @foreach (var p in _history)
                        {
                            <li>
                                <span class="list-label">@p.Source • @p.Amount.ToString("C") • @p.Mode</span>
                                <span class="tag">@p.PaidUtc.ToString("dd MMM yyyy HH:mm")</span>
                            </li>
                        }
                    </ul>
                }

                <h4 style="margin:0.8rem 0 0.35rem;">Payment Modes</h4>
                @if (_modes.Count == 0)
                {
                    <p style="color:var(--text-muted);">No payment mode history found.</p>
                }
                else
                {
                    <ul class="data-list">
                        @foreach (var mode in _modes.Take(15))
                        {
                            <li>
                                <span class="list-label">@mode.Mode • @mode.Source • @mode.ReferenceId</span>
                                <span class="tag">@mode.OccurredUtc.ToString("dd MMM yyyy HH:mm")</span>
                            </li>
                        }
                    </ul>
                }
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="auth-status error" style="margin-top:0.7rem;">@_error</div>
            }
            @if (!string.IsNullOrWhiteSpace(_success))
            {
                <div class="auth-status success" style="margin-top:0.7rem;">@_success</div>
            }
        </article>
    </div>
}

@code {
    private bool _ready;
    private bool _busy;
    private string? _error;
    private string? _success;
    private string _search = string.Empty;
    private string _statusFilter = string.Empty;
    private List<BillingMonitorItemDto> _items = [];
    private BillingMonitorItemDto? _selected;
    private List<InvoicePaymentHistoryDto> _history = [];
    private List<PaymentModeHistoryDto> _modes = [];
    private int _overdue;
    private int _upcoming;
    private int _totalCount;

    private decimal _manualAmount;
    private DateTime _manualPaidDate = DateTime.UtcNow.Date;
    private string _manualMode = "Bank Transfer";
    private string _manualRef = string.Empty;
    private string _manualNotes = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Session.TryRestoreAsync();
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/auth/admin-login", true);
            return;
        }
        if (Session.Auth?.Role != "WrkPlanAdmin")
        {
            Nav.NavigateTo("/customerportal/dashboard", true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        var response = await Api.GetBillingMonitoringAsync(new BillingMonitoringFilterDto(
            PageNumber: 1,
            PageSize: 50,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
            PaymentStatus: string.IsNullOrWhiteSpace(_statusFilter) ? null : _statusFilter,
            SortBy: "renewal",
            SortOrder: "asc"));

        if (response?.Success != true || response.Data is null)
        {
            _error = response?.Error?.Message ?? "Unable to load billing monitoring.";
            _items = [];
        }
        else
        {
            _items = response.Data.Items.Items.ToList();
            _overdue = response.Data.OverdueCount;
            _upcoming = response.Data.UpcomingRenewalCount;
            _totalCount = response.Data.Items.TotalCount;
            if (_items.Count > 0)
            {
                await SelectRowAsync(_items[0]);
            }
        }

        _ready = true;
        StateHasChanged();
    }

    private async Task SelectRowAsync(BillingMonitorItemDto row)
    {
        _selected = row;
        var history = await Api.GetCustomerPaymentHistoryAsync(row.CustomerProfileId);
        _history = history?.Data?.ToList() ?? [];
        var modes = await Api.GetCustomerPaymentModesAsync(row.CustomerProfileId);
        _modes = modes?.Data?.ToList() ?? [];
        StateHasChanged();
    }

    private async Task RecordManualAsync()
    {
        _error = _success = null;
        if (_selected is null)
        {
            _error = "Select a billing row first.";
            return;
        }
        if (_manualAmount <= 0)
        {
            _error = "Amount must be greater than zero.";
            return;
        }

        _busy = true;
        try
        {
            var response = await Api.RecordManualPaymentAsync(new ManualPaymentCreateDto(
                _selected.CustomerProfileId,
                null,
                _manualAmount,
                _manualPaidDate,
                _manualMode,
                _manualRef,
                _manualNotes));

            if (response?.Success == true)
            {
                _success = "Manual payment recorded.";
                _manualAmount = 0;
                _manualRef = string.Empty;
                _manualNotes = string.Empty;
                await LoadAsync();
            }
            else
            {
                _error = response?.Error?.Message ?? "Manual payment failed.";
            }
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
