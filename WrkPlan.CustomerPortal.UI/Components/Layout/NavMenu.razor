        <NavLink class="menu-link" href="customerportal/resources">
            <span class="nav-icon">&#128218;</span> <span class="nav-text">Resources</span>
        </NavLink>
        <NavLink class="menu-link" href="customerportal/onboarding">
            <span class="nav-icon">&#9989;</span> <span class="nav-text">Onboarding Hub</span>
        </NavLink>
        <button class="menu-link menu-link-button" @onclick="RequestLogout">
            <span class="nav-icon">&#128682;</span> <span class="nav-text">Logout</span>
        </button>
    }
</nav>

<div class="sidebar-footer">WrkPlan v1.0 &bull; &copy; 2025</div>

@code {
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public EventCallback OnLogoutRequested { get; set; }

    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        Session.Changed += OnSessionChanged;
        await Session.TryRestoreAsync();
        _ready = true;
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    private void NavigateHome()
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/");
            return;
        }

        Nav.NavigateTo(Session.Auth?.Role == "WrkPlanAdmin" ? "/customerhub/dashboard" : "/customerportal/dashboard");
    }

    private async Task RequestLogout()
    {
        if (OnLogoutRequested.HasDelegate)
        {
            await OnLogoutRequested.InvokeAsync();
            return;
        }

        await Session.ClearAsync();
        Nav.NavigateTo("/", true);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}
