{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Free App Ports",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$ports=5148,5187; foreach ($p in $ports) { $conns=Get-NetTCPConnection -LocalPort $p -State Listen -ErrorAction SilentlyContinue; foreach ($c in $conns) { Stop-Process -Id $c.OwningProcess -Force -ErrorAction SilentlyContinue } }; Write-Host 'Ports cleaned: 5148, 5187'"
			],
			"problemMatcher": []
		},
		{
			"label": "Run API",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"WrkPlan.CustomerPortal.API\\WrkPlan.CustomerPortal.API.csproj",
				"--no-build"
			],
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "wrkplan"
			}
		},
		{
			"label": "Run UI",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
